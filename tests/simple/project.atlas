name = "My Project"
app_name = "My Project App"
backend = "METAL"
platform = "MACOS"
atlas_version = "alpha8"

[pack]
icon = "none"
supported_platforms = "all"

[renderer]
default = "deferred"
global_illumination = false 

[game]
main_scene = "main.ascene"
assets = ["assets/"]

[window]
dimensions = [1920, 1480]
mouse_capture = false
multisampling = false
ssaoScale = 1.0
