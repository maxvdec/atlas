app_name = "My Project App"
atlas_version = "alpha8"
backend = "METAL"
name = "My Project"
platform = "MACOS"

[game]
assets = ["assets/"]
main_scene = "main.ascene"

[pack]
icon = "none"
supported_platforms = "all"

[renderer]
default = "deferred"
global_illumination = false

[scripts]
SimpleLog = "assets/scripts/simpleLog.ts"

[window]
dimensions = [
    1920,
    1480,
]
mouse_capture = false
multisampling = false
ssaoScale = 1.0
